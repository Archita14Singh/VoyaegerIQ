# VoyagerIQ - Enterprise AI Travel Assistant Backend Configuration

# FastAPI Settings
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Azure AI Foundry Agent Service Configuration
# Endpoint format: https://<workspace-name>.<region>.projects.azure.ai
FOUNDRY_PROJECT_ENDPOINT=""
# The specific Azure AI Agent Deployment ID/Agent ID or name
FOUNDRY_AGENT_ID=""
FOUNDRY_AGENT_NAME=""
FOUNDRY_AGENT_VERSION=""
FOUNDRY_ISOLATION_KEY=""
# API authentication credential for access to the Azure Foundry project resources (optional, as DefaultAzureCredential is used)
FOUNDRY_API_KEY=""

# Local Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./voyageriq_mvp.db
